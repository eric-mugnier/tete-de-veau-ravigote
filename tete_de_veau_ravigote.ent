\@doanenote {1}
macro:->Donatien
Alphonse
François,
marquis
de
Sade
(1740--1814),
écrivain
français,
auteur
de
\textit
{Justine}
(1791)
et
\textit
{Les
120
journées
de
Sodome}
(réd.
1785).
Il
passa
plus
de
vingt-sept
ans
de
sa
vie
enfermé,
notamment
à
la
Bastille,
à
Vincennes
et
à
Charenton.
Son
nom
a
donné
le
terme
«~sadisme~».
\source
{fr.wikipedia.org/wiki/Marquis\_de\_Sade}
\@endanenote 
\@doanenote {2}
macro:->Monstre
de
la
mythologie
grecque,
serpent
gigantesque
à
neuf
têtes
qui
repoussaient
au
double
dès
qu’on
les
tranchait.
Tuer
l’Hydre
de
Lerne
constituait
le
deuxième
des
douze
travaux
d’Héraclès.\source
{fr.wikipedia.org/wiki/Hydre\_de\_Lerne}
\@endanenote 
\@doanenote {3}
macro:->Créature
extraterrestre
fictive
